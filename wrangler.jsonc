{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ph-heatmap",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "triggers": {
    "crons": []
  }
}
